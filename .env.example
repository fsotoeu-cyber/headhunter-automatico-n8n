# API Key de Groq (gratuita en console.groq.com)
# Formato: gsk_...
GROQ_API_KEY=your_groq_api_key_here

# Correo donde recibirás el CV generado
GMAIL_RECIPIENT=your_email@gmail.com

# ID de Google Sheets - Historial Completo
# Lo encuentras en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GSHEETS_HISTORIAL_ID=your_google_sheet_id

# ID de Google Sheets - Vacantes Procesadas
GSHEETS_VACANTES_ID=your_google_sheet_id
